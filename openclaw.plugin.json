{
  "id": "wildduck",
  "name": "WildDuck",
  "description": "Adds permissioned WildDuck REST email tools, thread-aware search, drafts, and debounced update events to OpenClaw. Supports multi-account configuration for shared servers.",
  "version": "0.2.0",
  "skills": [
    "skills/wildduck-email"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "WildDuck API base URL, without trailing slash. Used as default for all accounts."
      },
      "accessToken": {
        "description": "WildDuck access token or SecretRef. Used as default for all accounts.",
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "id"
            ],
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "env",
                  "file",
                  "exec"
                ]
              },
              "provider": {
                "type": "string",
                "default": "default"
              },
              "id": {
                "type": "string"
              }
            }
          }
        ]
      },
      "accessTokenEnv": {
        "type": "string",
        "default": "WILDDUCK_ACCESS_TOKEN",
        "description": "Environment variable containing the WildDuck access token."
      },
      "defaultUserId": {
        "type": "string",
        "description": "Default WildDuck user id for tools when userId is omitted and no account is configured."
      },
      "defaultAccount": {
        "type": "string",
        "description": "Default account id to use when account parameter is omitted."
      },
      "permissions": {
        "type": "array",
        "default": [
          "read"
        ],
        "items": {
          "type": "string",
          "enum": [
            "read",
            "draft",
            "send",
            "mutate",
            "filters",
            "admin",
            "watch"
          ]
        },
        "description": "Enabled capability groups for global/legacy config. Defaults to read-only."
      },
      "watch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "mode": {
            "type": "string",
            "enum": [
              "sse",
              "poll"
            ],
            "default": "sse"
          },
          "users": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "WildDuck user ids to watch for update events."
          },
          "debounceMs": {
            "type": "number",
            "default": 90000
          },
          "pollIntervalMs": {
            "type": "number",
            "default": 60000
          },
          "maxBufferedEvents": {
            "type": "number",
            "default": 200
          }
        }
      },
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "userId"
          ],
          "properties": {
            "userId": {
              "type": "string",
              "description": "WildDuck user id for this account."
            },
            "permissions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "read",
                  "draft",
                  "send",
                  "mutate",
                  "filters",
                  "admin",
                  "watch"
                ]
              },
              "description": "Permissions for this account. Inherits global permissions when omitted."
            },
            "apiUrl": {
              "type": "string",
              "description": "Override API URL for this account."
            },
            "accessToken": {
              "description": "Override access token for this account.",
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "source",
                    "id"
                  ],
                  "properties": {
                    "source": {
                      "type": "string",
                      "enum": [
                        "env",
                        "file",
                        "exec"
                      ]
                    },
                    "provider": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string"
                    }
                  }
                }
              ]
            },
            "accessTokenEnv": {
              "type": "string",
              "description": "Environment variable for this account's access token."
            },
            "username": {
              "type": "string",
              "description": "Username for authentication with the WildDuck server."
            },
            "password": {
              "description": "Password for authentication with the WildDuck server.",
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "source",
                    "id"
                  ],
                  "properties": {
                    "source": {
                      "type": "string",
                      "enum": [
                        "env",
                        "file",
                        "exec"
                      ]
                    },
                    "provider": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string"
                    }
                  }
                }
              ]
            },
            "passwordEnv": {
              "type": "string",
              "description": "Environment variable for this account's password."
            },
            "watch": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "sse",
                    "poll"
                  ],
                  "default": "sse"
                },
                "users": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "debounceMs": {
                  "type": "number",
                  "default": 90000
                },
                "pollIntervalMs": {
                  "type": "number",
                  "default": 60000
                },
                "maxBufferedEvents": {
                  "type": "number",
                  "default": 200
                }
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "apiUrl": {
      "label": "WildDuck API URL",
      "placeholder": "https://mail.example.com/api"
    },
    "accessToken": {
      "label": "WildDuck access token",
      "sensitive": true
    },
    "accessTokenEnv": {
      "label": "Access token environment variable"
    },
    "defaultUserId": {
      "label": "Default user id"
    },
    "defaultAccount": {
      "label": "Default account id"
    },
    "permissions": {
      "label": "Enabled permissions"
    },
    "accounts": {
      "label": "Per-account configuration"
    }
  }
}
